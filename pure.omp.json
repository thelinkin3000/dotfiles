{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "transient_prompt": {
    "template": " <#00A192,transparent>~~> </>",
    "foreground": "#ffffff",
    "background": "transparent"
  },
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "always_enabled": true,
            "cache_duration": "none"
          },
          "template": " ",
          "foreground": "#b9dff6",
          "background": "#000000",
          "type": "exit",
          "style": "powerline",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#e74856{{ end }}"
          ]
        },
        {
          "properties": {
            "cache_duration": "none",
            "comment": "{{ if .SSHSession }} {{ end }}{{ .UserName }}@{{ .ComputerName }}",
            "display_host": true
          },
          "template": "{{ if .SSHSession }} {{ end }}{{ .UserName }}",
          "foreground": "#ffffff",
          "type": "session",
          "style": "powerline"
        },
        {
          "properties": {
            "cache_duration": "none",
            "folder_separator_icon": "/",
            "home_icon": "~",
            "style": "full"
          },
          "template": " {{ .Path }} ",
          "foreground": "#ffffff",
          "type": "path",
          "style": "powerline"
        },
        {
          "properties": {
            "branch_max_length": 50,
            "cache_duration": "none",
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{ .BranchStatus }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}",
          "foreground": "#fff",
          "type": "git",
          "style": "powerline",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#872700{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#872700{{ end }}",
            "{{ if gt .Ahead 0 }}#2B2D42{{ end }}",
            "{{ if gt .Behind 0 }}#2B2D42{{ end }}"
          ]
        },
        {
          "properties": {
            "cache_duration": "none",
            "fetch_version": true
          },
          "template": "  {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "foreground": "#111111",
          "powerline_symbol": "",
          "background": "#8ED1F7",
          "type": "go",
          "style": "powerline"
        },
        {
          "properties": {
            "cache_duration": "none",
            "display_mode": "files",
            "fetch_version": true,
            "fetch_virtual_env": false
          },
          "template": "  {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }} ",
          "foreground": "#111111",
          "powerline_symbol": "",
          "background": "#FFDE57",
          "type": "python",
          "style": "powerline"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "properties": {
            "cache_duration": "none",
            "threshold": 400
          },
          "template": " {{ .FormattedMs }}⠀",
          "foreground": "#ffffff",
          "powerline_symbol": "",
          "background": "#00201D",
          "type": "executiontime",
          "style": "powerline",
          "invert_powerline": true
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "{{ .Name }}  ~~>",
          "foreground": "#b9dff6",
          "background": "#ffffffff",
          "type": "shell",
          "style": "diamond"
        }
      ],
      "newline": true
    }
  ],
  "version": 3,
  "final_space": true
}
