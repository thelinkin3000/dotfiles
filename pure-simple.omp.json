{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "transient_prompt": {
    "template": " <#00A192,transparent>~~> </>",
    "foreground": "#ffffff",
    "background": "transparent"
  },
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "cache_duration": "none",
            "folder_separator_icon": "/",
            "home_icon": "~",
            "style": "full"
          },
          "template": "{{ .Path }} ",
          "foreground": "#ffffff",
          "type": "path",
          "style": "powerline",
          "mapped_locations": {
            "C:\\repos": ""
          }
        },
        {
          "properties": {
            "branch_max_length": 50,
            "cache_duration": "none",
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": "{{ .HEAD }} {{ .BranchStatus }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }} ",
          "foreground": "#b9dff6",
          "type": "git",
          "style": "powerline",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#e74856{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#e74856{{ end }}",
            "{{ if gt .Ahead 0 }}#2B2D42{{ end }}",
            "{{ if gt .Behind 0 }}#2B2D42{{ end }}"
          ]
        },
        {
          "properties": {
            "cache_duration": "none",
            "threshold": 100
          },
          "template": " {{ .FormattedMs }}⠀",
          "foreground": "#f9f1a5",
          "type": "executiontime",
          "style": "plain"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": []
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "{{ .Name }}  ~~>",
          "foreground": "#b9dff6",
          "background": "#ffffffff",
          "type": "shell",
          "style": "diamond"
        }
      ],
      "newline": true
    }
  ],
  "version": 3,
  "final_space": true
}
